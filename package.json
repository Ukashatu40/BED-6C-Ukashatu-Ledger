{
  "name": "bed-6c-ukashatu-ledger",
  "version": "1.0.0",
  "description": "Ledger System with Double-Entry Accounting & Immutable Audit Trail — Zetheta Assessment BED-6C",
  "author": "Ukashatu",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"seeds/**/*.ts\" \"scripts/**/*.ts\" \"tests/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,seeds,scripts,tests}/**/*.ts\"",
    "lint:fix": "eslint \"{src,seeds,scripts,tests}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --selectProjects unit --watch",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration --runInBand",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "ts-node -r tsconfig-paths/register seeds/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "db:migrate:test": "cross-env DATABASE_URL=postgresql://ledger_user:ledger_pass@localhost:5433/ledger_test_db?schema=public prisma migrate deploy",
    "db:seed:test": "cross-env DATABASE_URL=postgresql://ledger_user:ledger_pass@localhost:5433/ledger_test_db?schema=public ts-node -r tsconfig-paths/register seeds/seed.ts",
    "hash:verify": "ts-node -r tsconfig-paths/register scripts/verify-hashes.ts",
    "test:load:withdrawal": "k6 run tests/load/concurrent-withdrawal.js",
    "test:load:migration": "k6 run tests/load/migration-during-load.js",
    "test:stress": "jest --selectProjects integration --runInBand --testPathPattern=stress-test --testTimeout=180000",
    "trial-balance": "ts-node -r tsconfig-paths/register scripts/trial-balance-check.ts",
    "partitions:manage": "ts-node -r tsconfig-paths/register scripts/manage-partitions.ts"
  },
  "dependencies": {
    "@fastify/static": "^7.0.4",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-fastify": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/terminus": "^10.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "decimal.js": "^10.4.3",
    "fastify": "^4.0.0",
    "nestjs-pino": "^4.0.0",
    "pg": "^8.22.0",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "prom-client": "^15.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "uuidv7": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.7.0",
    "jest-util": "^30.4.1",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.0.0",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "typescript-eslint": "^8.0.0"
  }
}
